shell-integration = zsh
window-save-state = always

gtk-titlebar = false
cursor-style = block
mouse-hide-while-typing = true
window-decoration = false
background-opacity = 0.9

# theme = gruvbox-material-medium-light
theme = Monokai Pro Ristretto

font-family = Iosevka
font-size = 14
